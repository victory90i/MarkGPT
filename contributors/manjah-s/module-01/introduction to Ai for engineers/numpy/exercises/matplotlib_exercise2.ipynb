    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "x= np.arange(0, 5)\n",
    "y= x**2\n",
    "print(y, x)\n",
    "plt.plot(x, y, color= \"red\", linestyle= '--', linewidth=2.5)\n",
    "plt.title(\"first plot\")\n",
    "plt.xlabel(\"x-axis\")\n",
    "plt.ylabel(\"y-axis\")\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
