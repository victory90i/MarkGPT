   "source": [
    "import numpy as np\n",
    "v = np.array([3, 4])\n",
    "\n",
    "l1 = np.linalg.norm(v)\n",
    "l2 = np.linalg.norm(v, 1)\n",
    "l_infinity = np.linalg.norm(v, np.inf)\n",
    "\n",
    "print(l1, l2, l_infinity)"
   ]
  }
