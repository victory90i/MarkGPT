   "source": [
    "import numpy as np\n",
    "\n",
    "a=np.array([1,2,3])\n",
    "b=np.array([4,5,6])\n",
    "c= []\n",
    "total=0\n",
    "for num1, num2 in zip(a, b):\n",
    "    mult = num1*num2\n",
    "    c.append(mult)\n",
    "\n",
    "for val in c:\n",
    "    total+=val\n",
    "    \n",
    "\n",
    "dotproduct = np.dot(a, b)\n",
    "dotproduct2 = a @ b\n",
    "print(dotproduct, dotproduct2, total)"
   ]
  }
 ],
