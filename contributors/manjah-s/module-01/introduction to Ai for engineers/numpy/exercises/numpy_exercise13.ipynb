   "source": [
    "import numpy as np\n",
    "\n",
    "v= np.array([1, 0])\n",
    "theta= np.deg2rad(45)\n",
    "R = np.array([\n",
    "    [np.cos(theta), -np.cos(theta)],\n",
    "    [np.sin(theta), np.cos(theta)]\n",
    "])\n",
    "\n",
    "rotated = R @ v\n",
    "expected = np.array([np.cos([theta]), np.sin([theta])])\n",
    "\n",
    "print(rotated, np.allclose(rotated, expected))"
   ]
  }
 ],
