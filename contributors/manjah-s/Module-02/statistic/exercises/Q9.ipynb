   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "sizes = [8,14,12,4,2]\n",
    "labels = ['A','B','C','D','F']\n",
    "explode = [0,0,0,0,0.1]\n",
    "\n",
    "plt.pie(sizes, labels=labels, autopct='%1.1f%%', explode=explode)\n",
    "plt.legend()\n",
    "plt.title(\"Grade Distribution\")\n",
    "\n",
    "plt.show()"
   ]
  }
 ],
