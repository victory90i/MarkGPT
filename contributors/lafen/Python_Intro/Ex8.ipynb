   ],
   "source": [
    "raw_score = [15, -3, 200, 42, 0, 99, -7, 55, 188, 30]\n",
    "\n",
    "clipped_score = [min(max(x, 0), 100) for x in raw_score]\n",
    "normalized = [x / 100 for x in clipped_score]\n",
    "labels = [\"high\" if x >= 0.6 else \"low\" for x in normalized]\n",
    "print(clipped_score)\n",
    "print(normalized)\n",
    "print(labels)"
   ]
