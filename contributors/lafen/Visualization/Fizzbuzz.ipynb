    "output = []\n",
    "n = 100\n",
    "for x in range (n):\n",
    "    if x % 3 == 0 and x % 5 == 0:\n",
    "        output.append(\"FizzBuzz\")\n",
    "    elif x % 3 == 0:\n",
    "        output.append(\"Fizz\")\n",
    "    elif x % 5 == 0:\n",
    "        output.append(\"Buzz\")\n",
    "    else:\n",
    "        output.append(x)\n",
    "print(output)        "
