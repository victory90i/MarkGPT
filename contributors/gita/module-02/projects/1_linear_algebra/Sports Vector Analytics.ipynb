    "def plot_similarity_heatmap(C, names):\n",
    "    \"\"\"Plot the cosine similarity matrix as a heatmap\"\"\"\n",
    "    fig, ax=plt.subplots(figsize=(10,8))\n",
    "    im=ax.imshow(C, cmap=\"Blues\", vmin=0, vmax=1)\n",
    "    # thick labels on both axes\n",
    "    ax.set_xticks(range(len(names)))\n",
    "    ax.set_yticks(range(len(names)))\n",
    "    ax.set_xticklabels(names, rotation=45, ha='right', fontsize=10)\n",
    "    ax.set_yticklabels(names, fontsize=10)\n",
    "\n",
    "    # annotate each cell with its values\n",
    "    for i in range(len(names)):\n",
    "        for j in range(len(names)):\n",
    "            ax.text(j, i, f'{C[i,j]:.2f}', ha='center', va='center', fontsize=8, color='navy' if C[i, j] < 0.8 else 'white')\n",
    "    plt.colorbar(im, ax=ax, label='Cosine Similarity') \n",
    "    ax.set_title('Player Similarity Matrix (Cosine Similarity)',fontsize=13)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "plot_similarity_heatmap(C, names)    "
   ]
  },
