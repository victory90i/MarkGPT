    "def plot_top_similar(target_name, players_dict, top_k=5):\n",
    "    # bar chart of top-k most similar players to a given target\n",
    "    target_vec=players_dict[target_name]\n",
    "    sims = [(n, cosine_similarity(target_vec, v))\n",
    " for n, v in players_dict.items() if n != target_name]\n",
    "    sims.sort(key=lambda x: x[1], reverse=True)\n",
    "    top_names=[s[0] for s in sims[:top_k]]\n",
    "    top_scores=[s[1] for s in sims[:top_k]]\n",
    "    fig, ax=plt.subplots(figsize=(8, 5))\n",
    "    bars=ax.barh(top_names, top_scores, color='navy', alpha=0.8)\n",
    "    ax.set_xlim(0,1)\n",
    "    ax.set_xlabel('Cosine Similarity', fontsize=11)\n",
    "    ax.set_title(f'Top {top_k} players  most similar to {target_name}', fontsize=12)\n",
    "    ax.bar_label(bars, fmt='%.3f', padding=4, fontsize=10)\n",
    "    ax.invert_yaxis()\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
