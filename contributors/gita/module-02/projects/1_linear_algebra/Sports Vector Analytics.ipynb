     "output_type": "stream",
     "text": [
      "\n",
      " Most balanced player: De Bruyne\n",
      "Max/Min ratio: 2.16\n",
      "(A ratio of 1.0 would mean perfectly equal in every stat)\n"
     ]
    }
   ],
   "source": [
    "# The 'most balanced' player is the one whose norm is closest to having\n",
    "# equal components. We can find this by comparing max(v) / min(v) ratio.\n",
    "# A perfectly balanced player has ratio = 1 (all stats equal).\n",
    "\n",
    "balance_ratio=[]\n",
    "\n",
    "for name in names:\n",
    "    v=players[name]\n",
    "    ratio=np.max(v)/ (np.min(v) + 1e-8) # 1e-8 avoid divison by zero\n",
    "    balance_ratio.append(ratio)\n",
    "\n",
    "most_balanced_idx=np.argmin(balance_ratio)\n",
    "print(f'\\n Most balanced player: {names[most_balanced_idx]}')\n",
    "print(f'Max/Min ratio: {balance_ratio[most_balanced_idx]:.2f}')\n",
    "print('(A ratio of 1.0 would mean perfectly equal in every stat)')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "97bc4650-803a-4848-9f97-0929e7aaea51",
   "metadata": {},
   "source": [
    "## Step 3 — Cosine similarity, built from scratch\n",
    "\n",
    "This is the core of the project. We implement cosine similarity entirely from first principles — no\n",
    "sklearn, no scipy. "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "91ef60a0-b9f0-4e6f-8be3-0f4a0007c8ff",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "np.float64(1.0)"
      ]
     },
     "execution_count": 10,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def cosine_similarity(a, b):\n",
    "    dot=np.dot(a,b);\n",
    "    norm_a=np.linalg.norm(a);\n",
    "    norm_b=np.linalg.norm(b);\n",
    "    return dot/(norm_a*norm_b);\n",
    "cosine_similarity(9,4)"
   ]
  },
